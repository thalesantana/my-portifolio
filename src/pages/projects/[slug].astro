---
import Footer from "../../components/layout/Footer.astro";
import Header from "../../components/layout/Header.astro";
import TechChip from "../../components/ui/TechChip.astro";
import BaseLayout from "../../layouts/BaseLayout.astro";
import { assetUrl, getProject } from "../../lib/directus";

const { slug } = Astro.params;

if (!slug) {
  return Astro.redirect("/projects");
}

const project = await getProject(slug).catch(() => null);

if (!project) {
  return Astro.redirect("/projects");
}

const thumbnail = assetUrl(project.cover_image);
---

<BaseLayout
  title={`${project.title} — Portfolio`}
  description={project.description}
  ogImage={thumbnail ?? undefined}
>
  <Header />

  <main class="pt-32 pb-32">
    <!-- ── CASE STUDY HERO ─────────────────────────── -->
    <section class="max-w-7xl mx-auto px-6 mb-24">
      <!-- Breadcrumb -->
      <nav class="flex items-center gap-3 mb-12">
        <a
          href="/projects"
          class="text-xs font-mono text-outline hover:text-primary tracking-wider uppercase transition-colors"
        >
          Projects
        </a>
        <span class="text-outline-variant">/</span>
        <span
          class="text-xs font-mono text-on-surface-variant tracking-wider uppercase"
          >{project.title}</span
        >
      </nav>

      <div class="grid grid-cols-1 lg:grid-cols-3 gap-16">
        <!-- Left: meta -->
        <div class="lg:col-span-1 order-2 lg:order-1">
          <div class="sticky top-24 space-y-8">
            <!-- Year -->
            <div>
              <p
                class="text-xs font-mono text-outline tracking-widest uppercase mb-2"
              >
                Year
              </p>
              <p class="text-sm text-on-surface font-mono">
                {new Date(project.date_created).getFullYear()}
              </p>
            </div>

            <!-- Tech Stack -->
            {
              project.tech_stack?.length > 0 && (
                <div>
                  <p class="text-xs font-mono text-outline tracking-widest uppercase mb-3">
                    Tech Stack
                  </p>
                  <div class="flex flex-wrap gap-2">
                    {project.tech_stack.map((tech) => (
                      <TechChip label={tech} />
                    ))}
                  </div>
                </div>
              )
            }

            <!-- Links -->
            <div class="space-y-3">
              {
                project.live_url && (
                  <a
                    href={project.live_url}
                    target="_blank"
                    rel="noopener noreferrer"
                    class="flex items-center gap-2 text-sm font-mono text-primary hover:text-[#68fcbf] transition-colors"
                  >
                    <span class="w-1.5 h-1.5 bg-primary rounded-full" />
                    Live Demo →
                  </a>
                )
              }
              {
                project.repo_url && (
                  <a
                    href={project.repo_url}
                    target="_blank"
                    rel="noopener noreferrer"
                    class="flex items-center gap-2 text-sm font-mono text-on-surface-variant hover:text-on-surface transition-colors"
                  >
                    <span class="w-1.5 h-1.5 bg-outline rounded-full" />
                    GitHub →
                  </a>
                )
              }
            </div>
          </div>
        </div>

        <!-- Right: content -->
        <div class="lg:col-span-2 order-1 lg:order-2">
          <p
            class="text-xs font-mono text-primary tracking-[0.3em] uppercase mb-4"
          >
            Case Study
          </p>
          <h1
            class="font-display text-5xl font-bold text-on-surface mb-4 leading-tight"
          >
            {project.title}
          </h1>
          <p class="text-xl text-on-surface-variant mb-8">
            {project.description}
          </p>

          {/* Thumbnail */}
          {
            thumbnail && (
              <div class="aspect-video bg-surface-lowest overflow-hidden mb-12">
                <img
                  src={thumbnail}
                  alt={project.title}
                  class="w-full h-full object-cover"
                />
              </div>
            )
          }
        </div>
      </div>
    </section>

    <!-- ── DESCRIPTION ────────────────────────────── -->
    <section class="bg-surface-low py-24">
      <div class="max-w-7xl mx-auto px-6">
        <div class="max-w-3xl">
          <p
            class="text-xs font-mono text-primary tracking-[0.3em] uppercase mb-6"
          >
            Overview
          </p>
          <div
            class="prose prose-invert prose-sm max-w-none text-on-surface-variant leading-relaxed whitespace-pre-wrap"
          >
            {project.long_description || project.description}
          </div>
        </div>
      </div>
    </section>

    <!-- ── IMAGE GALLERY ──────────────────────────── -->

    <!-- ── NAV: BACK ──────────────────────────────── -->
    <div class="max-w-7xl mx-auto px-6 mt-16">
      <a
        href="/projects"
        class="inline-flex items-center gap-3 text-sm font-mono text-primary hover:text-[#68fcbf] transition-colors"
      >
        ← All Projects
      </a>
    </div>
  </main>

  <Footer />
</BaseLayout>
