---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Header from '../../components/layout/Header.astro';
import Footer from '../../components/layout/Footer.astro';
import ProjectCard from '../../components/ui/ProjectCard.astro';
import { getProjects } from '../../lib/directus';

let projects: Awaited<ReturnType<typeof getProjects>> = [];

try {
  projects = await getProjects();
} catch {
  // Directus not available
}
---

<BaseLayout
  title="Projects — Portfolio"
  description="A collection of engineering projects spanning distributed systems, cloud infrastructure, and developer tooling."
>
  <Header />

  <main class="pt-32 pb-32">
    <div class="max-w-7xl mx-auto px-6">
      <!-- Page header -->
      <div class="mb-20">
        <p class="text-xs font-mono text-primary tracking-[0.3em] uppercase mb-4">All Work</p>
        <h1 class="font-display text-6xl font-bold text-on-surface mb-6">Projects</h1>
        <p class="text-on-surface-variant max-w-xl text-lg">
          End-to-end engineering from architecture to deployment.
          Each project is a live schematic of engineering decisions.
        </p>
      </div>

      <!-- Project count -->
      <div class="flex items-center gap-4 mb-12 pb-6 border-b border-outline-variant/20">
        <span class="text-xs font-mono text-outline tracking-widest uppercase">
          {projects.length} {projects.length === 1 ? 'project' : 'projects'}
        </span>
        <div class="flex-1 h-px bg-outline-variant/20"></div>
      </div>

      {projects.length > 0 ? (
        <!-- Projects grid -->
        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-px bg-outline-variant/20">
          {projects.map((project) => (
            <ProjectCard project={project} />
          ))}
        </div>
      ) : (
        <!-- Empty state -->
        <div class="text-center py-32">
          <p class="text-xs font-mono text-outline tracking-widest uppercase mb-4">No projects yet</p>
          <p class="text-on-surface-variant">Projects will appear here once added via Directus.</p>
        </div>
      )}
    </div>
  </main>

  <Footer />
</BaseLayout>
